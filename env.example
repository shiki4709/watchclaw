# Watchclaw Environment Variables
# Copy this file to .env and fill in your values

# ── SHARED (used by both collector and server) ────────────────────────────────

# Secret token — must match between collector and server
# Generate one: openssl rand -hex 16
WATCHCLAW_TOKEN=changeme

# ── SERVER ────────────────────────────────────────────────────────────────────

# Port the server runs on
PORT=3001

# Discord webhook URL for alerts
# How to get one:
#   1. Open Discord
#   2. Go to any server you own → Settings → Integrations → Webhooks
#   3. Click "New Webhook", copy the URL
#   For a DM to yourself: create a private server, add a webhook there
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Path to SQLite database file
DB_PATH=./watchclaw.db

# ── COLLECTOR ────────────────────────────────────────────────────────────────

# URL of your Watchclaw server
# Local development:
WATCHCLAW_SERVER_URL=http://localhost:3001
# Deployed (Railway, Render, etc.):
# WATCHCLAW_SERVER_URL=https://watchclaw-server.up.railway.app

# Name for this agent (shows in dashboard and Discord alerts)
AGENT_NAME=OpenClaw

# Path to OpenClaw log file
# Find yours by running: find ~ -name "*.log" | grep -i openclaw
OPENCLAW_LOG_FILE=~/.openclaw/logs/openclaw.log
